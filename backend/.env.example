PORT=3000
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Supabase verification emails return here. Use the deployed frontend HTTPS
# origin in production; the first safe CORS origin is used when this is omitted.
AUTH_EMAIL_REDIRECT_URL=http://localhost:5173
EMAIL_VERIFICATION_TTL_SECONDS=3600
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# Supabase credentials are server-only. Never prefix these with VITE_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Data-GSM credentials are server-only.
DATA_GSM_BASE_URL=https://openapi.datagsm.kr
DATA_GSM_API_KEY=your-api-key-here
DATA_GSM_TIMEOUT_MS=5000
DATA_GSM_PROFILE_TTL_SECONDS=300
DATA_GSM_SCHEDULE_TTL_SECONDS=3600
CACHE_KEY_SECRET=your-cache-key-here

# Campus AI is called only by this backend. Do not expose this as a VITE_ value.
# AI_BASE_URL is the server origin only; /v1/chat is appended by the client.
# Public AI servers must use HTTPS.
AI_BASE_URL=https://api.71battery.p-e.kr
CAMPUS_AI_TOP_K=4
CAMPUS_AI_SCORE_THRESHOLD=1.5
CAMPUS_AI_CONNECT_TIMEOUT=5
CAMPUS_AI_READ_TIMEOUT=60

# Explicit local/test-only opt-ins. Never enable in production.
ALLOW_IN_MEMORY_AUTH=false
ALLOW_IN_MEMORY_REPOSITORY=false
