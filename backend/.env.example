PORT=3000
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Supabase credentials are server-only. Never prefix these with VITE_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Data-GSM credentials are server-only.
DATA_GSM_BASE_URL=https://openapi.datagsm.kr
DATA_GSM_API_KEY=your-api-key-here
DATA_GSM_TIMEOUT_MS=5000
DATA_GSM_PROFILE_TTL_SECONDS=300
DATA_GSM_SCHEDULE_TTL_SECONDS=3600
CACHE_KEY_SECRET=your-cache-key-here

# Campus AI is called only by this backend. Do not expose these as VITE_ values.
# Production requires an HTTPS origin.
CAMPUS_AI_API_URL=https://your-campus-ai-service.example.com
CAMPUS_AI_TOP_K=4
CAMPUS_AI_SCORE_THRESHOLD=1.5
CAMPUS_AI_CONNECT_TIMEOUT=5
CAMPUS_AI_READ_TIMEOUT=60

# Explicit local/test-only opt-ins. Never enable in production.
ALLOW_IN_MEMORY_AUTH=false
ALLOW_IN_MEMORY_REPOSITORY=false
